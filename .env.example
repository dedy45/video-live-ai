# Environment Configuration
# Copy this to .env and fill in your values

# === LLM API Keys (digunakan oleh LiteLLM) ===
# LiteLLM otomatis membaca env vars ini sesuai provider
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
# Chutes.ai — Bearer token (bukan API key biasa)
CHUTES_API_TOKEN=your_chutes_api_token_here
# Multiple Groq keys untuk key rotation (pisahkan dengan koma)
# GROQ_API_KEYS=key1,key2,key3

# === Local LLM (Ollama/vLLM) ===
LOCAL_LLM_URL=http://localhost:11434/v1

# === Local Gemini Proxy (localhost:8091) ===
# OpenAI-compatible proxy that exposes Gemini models locally
# Available models: gemini-3.1-pro-high, gemini-3-flash
LOCAL_GEMINI_URL=http://127.0.0.1:8091/v1
LOCAL_GEMINI_API_KEY=sk-231d5e6912b44d929ac0b93ba2d2e033

# === Platform Credentials ===
TIKTOK_SESSION_ID=your_tiktok_session_id
SHOPEE_API_KEY=your_shopee_api_key

# === Streaming ===
TIKTOK_RTMP_URL=rtmp://push.tiktokcdn.com/live/
TIKTOK_STREAM_KEY=your_stream_key
SHOPEE_RTMP_URL=
SHOPEE_STREAM_KEY=

# === LiveTalking Engine ===
LIVETALKING_ENABLED=false
LIVETALKING_PORT=8010
LIVETALKING_TRANSPORT=webrtc
LIVETALKING_MODEL=musetalk
LIVETALKING_AVATAR_ID=musetalk_avatar1
LIVETALKING_REFERENCE_VIDEO=assets/avatar/reference.mp4
LIVETALKING_REFERENCE_AUDIO=assets/avatar/reference.wav
LIVETALKING_USE_WEBRTC=false
LIVETALKING_USE_RTMP=true
LIVETALKING_FPS=30
LIVETALKING_RESOLUTION=512,512
FFMPEG_BIN=tools/ffmpeg/bin/ffmpeg.exe
MOCK_MODE=true
ENV=development
LOG_LEVEL=DEBUG

# === GPU Configuration ===
GPU_DEVICE=cuda:0
GPU_VRAM_BUDGET_MB=20000

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme
