# AI Live Commerce Platform - Git Ignore

## ========================================
## UV Package Manager (bukan conda!)
## ========================================
# UV virtual environment (JANGAN di-commit!)
.venv/
**/.venv/
.venv-*/
**/.venv-*/
venv/
**/venv/
uv.lock

# UV cache
.uv/

## ========================================
## Python
## ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
build/
*.egg

## ========================================
## Node.js (Svelte Dashboard Frontend)
## ========================================
node_modules/
src/dashboard/frontend/dist/

## ========================================
## Environment & Secrets
## ========================================
# JANGAN commit API keys!
.env

# Keep example file
!.env.example

## ========================================
## Models & Weights (BESAR, download terpisah)
## ========================================
# Model weights (bisa 10-20GB per model)
models/
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.onnx
*.tflite
*.h5
*.pb
*.pkl
*.pickle

# Fish-Speech checkpoints (5-10GB)
external/fish-speech/checkpoints/
external/fish-speech/runtime/.venv/

# LiveTalking models (15-20GB total)
external/livetalking/models/
external/livetalking/models_download/
external/livetalking/data/avatars/
external/livetalking/data/videos/
external/livetalking/data/audios/

# FFmpeg binaries (100-200MB)
tools/ffmpeg/

# Keep folder structure & documentation
!models/.gitkeep
!models/README.md
!external/fish-speech/checkpoints/.gitkeep
!external/fish-speech/checkpoints/README.md
!external/livetalking/models/.gitkeep
!external/livetalking/models/README.md
!external/livetalking/data/avatars/.gitkeep
!external/livetalking/data/avatars/README.md

## ========================================
## Data & Cache (Runtime generated)
## ========================================
# Database files (bisa besar jika banyak data)
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-shm
data/*.db-wal
data/cache/
data/logs/

# Output files (video/audio hasil render)
output/
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.wav
*.mp3
*.flac
*.aac

# Temporary processing files
temp/
tmp/
*.tmp
*.temp

# Keep folder structure
!data/.gitkeep
!data/logs/.gitkeep
!output/.gitkeep
!output/README.md

# Keep sample files (kecil, untuk testing)
!data/sample*.db
!output/sample*.mp4

## ========================================
## Assets (User-provided, bisa besar)
## ========================================
# Avatar reference files (video 5 menit bisa 500MB+)
assets/avatar/*.mp4
assets/avatar/*.avi
assets/avatar/*.mov
assets/avatar/*.mkv
assets/avatar/*.webm

# Avatar images (high-res bisa 10-50MB per file)
assets/avatar/*.jpg
assets/avatar/*.png
assets/avatar/*.jpeg
assets/avatar/*.bmp
assets/avatar/*.tiff

# Voice samples (audio panjang bisa 50-100MB)
assets/voice/*.wav
assets/voice/*.mp3
assets/voice/*.flac
assets/voice/*.aac
assets/voice/*.ogg

# Product images (ratusan produk = ratusan MB)
assets/products/*.jpg
assets/products/*.png
assets/products/*.jpeg
assets/products/*.webp

# Background videos (bisa 1-2GB)
assets/backgrounds/*.mp4
assets/backgrounds/*.avi
assets/backgrounds/*.mov
assets/backgrounds/*.webm

# Keep folder structure & sample files
!assets/avatar/.gitkeep
!assets/avatar/README.md
!assets/avatar/sample-*.jpg
!assets/voice/.gitkeep
!assets/voice/README.md
!assets/voice/sample-*.wav
!assets/backgrounds/.gitkeep
!assets/backgrounds/README.md
!assets/products/.gitkeep
!assets/products/README.md
!assets/products/sample-*.jpg

## ========================================
## External Dependencies (Git Submodules)
## ========================================
# LiveTalking submodule - ignore runtime files
external/livetalking/__pycache__/
external/livetalking/*.log
external/livetalking/*.pyc
external/livetalking/.pytest_cache/

# Fish-Speech upstream - ignore cache
external/fish-speech/upstream/__pycache__/
external/fish-speech/upstream/.pytest_cache/

# Keep submodule structure
!external/livetalking/.git
!external/livetalking/.gitignore
!external/fish-speech/.git
!external/fish-speech/.gitignore

